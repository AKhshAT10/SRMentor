# ---- SRM MentorConnect frontend environment ----

# Only needed for a SPLIT deployment where the frontend and backend are hosted
# separately (for example frontend on Vercel, backend on Render). Set it to the
# full backend origin, with no trailing slash, e.g. https://your-api.onrender.com
#
# For a single-service deploy (backend serves the built frontend) leave this unset.
VITE_API_BASE_URL=
